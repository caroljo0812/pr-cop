# PR Cop environment configuration

# LLM provider for reviewer agents (default: Xiaomi MiMo v2.5 Pro)
# Options: mimo (default), openai, together, gateway, mock
PRCOP_LLM_PROVIDER=mimo
PRCOP_LLM_API_KEY=
PRCOP_LLM_MODEL=mimo-v2.5-pro
PRCOP_LLM_BASE_URL=

# GitHub integration (only needed for posting PR comments)
PRCOP_GITHUB_TOKEN=

# Server
PRCOP_HOST=0.0.0.0
PRCOP_PORT=8080

# Concurrency: how many specialist agents to run in parallel (default: 4)
PRCOP_CONCURRENCY=4

# Token budget per reviewer agent (rough cap, the LLM provider will enforce)
PRCOP_MAX_TOKENS=1200
